# =============================================================================
# AI Knowledge Base — Environment Variables
# Copy this file to .env and fill in real values. setup.sh does the copy for you.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com -> Project Settings -> API)
# -----------------------------------------------------------------------------
# Used by the NestJS API (server-side, full access via service role).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # NEVER expose to the browser

# Used by the Next.js web app (browser-safe, RLS-protected).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# -----------------------------------------------------------------------------
# AI Provider — CHAT (any OpenAI-compatible endpoint)
# Examples:
#   OpenAI     base_url=https://api.openai.com/v1            model=gpt-4o-mini
#   Groq       base_url=https://api.groq.com/openai/v1       model=llama-3.3-70b-versatile
#   Together   base_url=https://api.together.xyz/v1          model=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   OpenRouter base_url=https://openrouter.ai/api/v1         model=openai/gpt-4o-mini
#   Ollama     base_url=http://localhost:11434/v1            model=llama3.1
# -----------------------------------------------------------------------------
AI_CHAT_BASE_URL=https://api.openai.com/v1
AI_CHAT_API_KEY=your-chat-provider-api-key
AI_CHAT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# AI Provider — EMBEDDINGS (split from chat: some providers do one but not both)
# IMPORTANT: AI_EMBEDDING_DIMENSIONS MUST match the vector(N) size in the
# document_chunks migration. Default 1536 = text-embedding-3-small.
# If you change the model/dimensions, update the migration before first run.
# -----------------------------------------------------------------------------
AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
AI_EMBEDDING_API_KEY=your-embedding-provider-api-key
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# App wiring
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development
